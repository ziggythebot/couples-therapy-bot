{
  "name": "couples-bot",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/session-api",
    "dev:web": "npm run dev --workspace=apps/intake-web",
    "build": "npm run build --workspaces --if-present",
    "poc": "tsx src/pipeline/runPoc.ts",
    "parse:chat": "tsx src/whatsapp/parseWhatsapp.ts",
    "test": "tsx --test src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.5",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
